APP_NAME=Leadiva

# Neon PostgreSQL (pooled). Alias NEON_DB_URL also accepted.
DATABASE_URL=
# Optional direct URL for migrations
DATABASE_URL_DIRECT=

# Auth.js
AUTH_SECRET=

# Comma-separated Creativa email domains
ALLOWED_EMAIL_DOMAINS=creativastudios.us,creativaconsultores.com,creativatechstudios.com

# Optional: protect internal sync job endpoints
JOB_SYNC_SECRET=

# COMPRASAL public API (free — never use Google Search for this source)
COMPRASAL_BASE_URL=https://www.comprasal.gob.sv/api/v1
COMPRASAL_SYNC_MAX_PAGES=3
COMPRASAL_REQUEST_TIMEOUT_MS=45000
COMPRASAL_MAX_RETRIES=2
COMPRASAL_AVAILABLE_PER_PAGE=1000
COMPRASAL_AVAILABLE_MAX_PAGES=100
COMPRASAL_AVAILABLE_MAX_ROWS=10000
COMPRASAL_AVAILABLE_MAX_MATCHES=250
COMPRASAL_AVAILABLE_CACHE_TTL_MS=300000
COMPRASAL_AWARD_REPORT_CACHE_TTL_MS=300000
COMPRASAL_PROCESS_DETAIL_CACHE_TTL_MS=300000
COMPRASAL_AVAILABLE_TIME_BUDGET_MS=240000

# Vertex AI / Google Search Grounding (sector privado)
# Usa Application Default Credentials (ADC):
#   gcloud auth application-default login
#   gcloud config set project YOUR_PROJECT_ID
GCP_PROJECT_ID=
GCP_LOCATION=us-central1
VERTEX_MODEL=gemini-2.5-flash-lite
# Discovery: Flash-Lite por defecto (cuota). Usa gemini-2.5-flash solo si tienes cuota.
VERTEX_GROUNDING_MODEL=gemini-2.5-flash-lite
VERTEX_GROUNDING_LOCATION=global
SEARCH_MAX_QUERIES=8
# Cada pass = 1 llamada Vertex + Search. Mantén estos límites para controlar costo.
SEARCH_GROUNDING_PASSES=4
SEARCH_GROUNDING_CONCURRENCY=2
SEARCH_GROUNDING_MAX_OUTPUT_TOKENS=4096
SEARCH_NORMALIZATION_MAX_OUTPUT_TOKENS=4096
SEARCH_TARGET_UNIQUE_CANDIDATES=10
SEARCH_MAX_CONSECUTIVE_EMPTY_PASSES=2
SEARCH_MAX_INPUT_TOKENS=24000
SEARCH_MAX_OUTPUT_TOKENS=16000
SEARCH_MAX_ESTIMATED_COST=0.02
# 0.20–0.30 recomendado: la región complementa las búsquedas globales.
SEARCH_REGIONAL_SHARE=0.25
SEARCH_MAX_CANDIDATES=25

# Private web hybrid discovery. Keep GROUNDING_ONLY as the production default.
PRIVATE_WEB_DISCOVERY_MODE=GROUNDING_ONLY
BRAVE_SEARCH_API_KEY=
BRAVE_SEARCH_COST_PER_REQUEST=0.005
PRIVATE_WEB_MAX_PROVIDER_QUERIES=8
PRIVATE_WEB_RESULTS_PER_QUERY=10
PRIVATE_WEB_MAX_PAGES_PER_QUERY=1
PRIVATE_WEB_MAX_PROVIDER_RESULTS=80
PRIVATE_WEB_MAX_UNIQUE_URLS=40
PRIVATE_WEB_MAX_URLS_PER_DOMAIN=3
PRIVATE_WEB_SEARCH_CONCURRENCY=2
PRIVATE_WEB_SEARCH_TIMEOUT_MS=10000
PRIVATE_WEB_SEARCH_MAX_RETRIES=2
PRIVATE_WEB_MAX_CONSECUTIVE_EMPTY_QUERIES=2
PRIVATE_WEB_MAX_FETCH_DOCUMENTS=15
PRIVATE_WEB_FETCH_CONCURRENCY=3
PRIVATE_WEB_FETCH_TIMEOUT_MS=12000
PRIVATE_WEB_MAX_DOCUMENT_BYTES=5000000
PRIVATE_WEB_MAX_REDIRECTS=4
PRIVATE_WEB_MAX_REQUESTS_PER_HOST=2
PRIVATE_WEB_FETCH_USER_AGENT=CreativaLeadsBot/1.0
PRIVATE_WEB_ROBOTS_CACHE_TTL_MS=3600000
PRIVATE_WEB_MAX_PDF_PAGES=30
PRIVATE_WEB_MAX_EXTRACTION_DOCUMENTS=12
PRIVATE_WEB_EXTRACTION_CONCURRENCY=2
PRIVATE_WEB_MAX_EXTRACTION_TOKENS=6000
PRIVATE_WEB_MAX_GROUNDING_VERIFICATIONS=3
PRIVATE_WEB_TARGET_CANDIDATES=8
PRIVATE_WEB_MAX_ESTIMATED_COST=0.10
